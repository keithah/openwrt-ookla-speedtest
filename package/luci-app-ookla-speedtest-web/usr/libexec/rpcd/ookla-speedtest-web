#!/usr/bin/env python3
import json, os, sys, subprocess

methods={
 'status':{}, 'servers':{}, 'start':{'server_id':''},
 'start_live':{'server_id':''}, 'live_status':{'job_id':''},
 'cancel_live':{'job_id':''}, 'history':{},
 'delete_history':{'id':''}, 'clear_history':{}, 'settings':{},
 'accept_terms':{}, 'begin_local':{}, 'cancel_local':{'run_id':''},
 'local_download':{'bytes':0}, 'local_upload':{'data':''},
 'record_local':{'run_id':'','download_mbps':'','upload_mbps':'','ping_ms':''}
}
if len(sys.argv)>1 and sys.argv[1]=='list':
 print(json.dumps(methods,separators=(',',':'))); raise SystemExit
if len(sys.argv)>2 and sys.argv[1]=='call':
 try: method=sys.argv[2]; params=json.loads(sys.stdin.read() or '{}'); assert isinstance(params,dict)
 except Exception: print(json.dumps({'error':'invalid_request'})); raise SystemExit
 if method not in methods: print(json.dumps({'error':'unknown_method'})); raise SystemExit
 env=os.environ.copy(); env['OOKLA_SPEEDTEST_BIN']=env.get('OOKLA_SPEEDTEST_BIN','/usr/bin/speedtest')
 helper=env.get('OOKLA_WEBD_HELPER','/usr/libexec/ookla-speedtest-webd')
 p=subprocess.run([helper],input=json.dumps(dict(params,method=method)),text=True,capture_output=True,env=env)
 print(p.stdout or json.dumps({'ok':False,'error':{'code':'service_error'}}))
