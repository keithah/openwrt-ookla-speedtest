#!/usr/bin/env python3
import json, os, sys, subprocess
methods=('status','servers','start','history','delete_history','clear_history','settings','accept_terms')
if len(sys.argv)>1 and sys.argv[1]=='list':
 print(json.dumps({'ookla-speedtest-web':{m:[] for m in methods}})); raise SystemExit
if len(sys.argv)>1 and sys.argv[1]=='call':
 try: method=sys.argv[3]; params=json.loads(sys.stdin.read() or '{}'); assert isinstance(params,dict)
 except Exception: print(json.dumps({'error':'invalid_request'})); raise SystemExit
 if method not in methods: print(json.dumps({'error':'unknown_method'})); raise SystemExit
 env=os.environ.copy(); env['OOKLA_SPEEDTEST_BIN']=env.get('OOKLA_SPEEDTEST_BIN','/usr/bin/speedtest')
 p=subprocess.run(['/usr/libexec/ookla-speedtest-webd'],input=json.dumps(dict(params,method=method)),text=True,capture_output=True,env=env)
 print(p.stdout or json.dumps({'ok':False,'error':{'code':'service_error'}}))
