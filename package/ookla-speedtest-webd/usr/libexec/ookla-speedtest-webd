#!/usr/bin/env python3
import os,sys,json,time,subprocess,fcntl,re,tempfile,errno,signal
run=os.environ.get('OOKLA_WEBD_RUN_DIR','/var/run/ookla-speedtest-webd'); hist=os.environ.get('OOKLA_WEBD_HISTORY','/etc/ookla-speedtest-webd/history.jsonl'); binary=os.environ.get('OOKLA_SPEEDTEST_BIN','/usr/bin/speedtest'); maxout=1024*1024
os.makedirs(run,exist_ok=True); os.makedirs(os.path.dirname(hist),exist_ok=True)
jobsdir=os.path.join(run,'jobs'); os.makedirs(jobsdir,exist_ok=True)
localjobsdir=os.path.join(run,'local-jobs'); os.makedirs(localjobsdir,exist_ok=True)
worker=os.environ.get('OOKLA_WEBD_WORKER',os.path.join(os.path.dirname(os.path.realpath(__file__)),'ookla-speedtest-webd-worker'))
def retention():
 try:
  v=os.environ.get('OOKLA_HISTORY_RETENTION','100')
  if not re.fullmatch(r'[0-9]+',v): raise ValueError
  n=int(v)
  if n<0 or n>10000: raise ValueError
  return n
 except Exception: return 100
def out(x): print(json.dumps(x,separators=(',',':')))
def new_id(): return os.urandom(16).hex()
def startingfile(job_id): return os.path.join(jobsdir,job_id+'.starting')
def has_starting():
 try: return any(re.fullmatch(r'[0-9a-f]{32}\.starting',name) for name in os.listdir(jobsdir))
 except OSError: return False
def lock(ignore_starting=False):
 if not ignore_starting and has_starting(): return None,None
 p=os.path.join(run,'start.lock')
 try: f=open(p,'w')
 except OSError: return ('storage_error',None)
 try:
  fcntl.flock(f,fcntl.LOCK_EX|fcntl.LOCK_NB)
  if not ignore_starting and has_starting():
   fcntl.flock(f,fcntl.LOCK_UN); f.close(); return None,None
  return f,None
 except BlockingIOError:
  f.close(); return None,None
 except OSError as e:
  if e.errno not in (errno.ENOSYS,errno.ENOTSUP,errno.EOPNOTSUPP):
   f.close(); return 'storage_error',None
  f.close(); d=p+'.d'
  try:
   os.mkdir(d)
   if not ignore_starting and has_starting(): os.rmdir(d); return None,None
   return None,d
  except Exception: return None,None
def unlock(x):
 f,d=x
 if f:
  try: fcntl.flock(f,fcntl.LOCK_UN); f.close()
  except: pass
 if d:
  try: os.rmdir(d)
  except: pass
statefile=os.path.join(run,'state.json')
termsfile=os.environ.get('OOKLA_WEBD_TERMS',os.path.join(os.path.dirname(hist),'terms-accepted'))
servercachefile=os.path.join(run,'servers-cache.json')
_servers_cache=None; _servers_cache_at=0
def atomic_write(path,data):
 d=os.path.dirname(path) or '.'; fd,tmp=tempfile.mkstemp(prefix='.tmp-',dir=d)
 try:
  with os.fdopen(fd,'w') as f: f.write(data); f.flush(); os.fsync(f.fileno())
  os.replace(tmp,path)
  try:
   dfd=os.open(d,os.O_DIRECTORY); os.fsync(dfd); os.close(dfd)
  except OSError: pass
 except Exception:
  try: os.unlink(tmp)
  except OSError: pass
  raise
def writestate(s): atomic_write(statefile,json.dumps(s,separators=(',',':')))
def terms_accepted(): return os.path.exists(termsfile)
def writehist(items):
 atomic_write(hist,''.join(json.dumps(x,separators=(',',':'))+'\n' for x in items))
def readhist():
 try:
  with open(hist) as f: lines=f.read().splitlines()
  n=retention(); return [json.loads(x) for x in (lines if n==0 else lines[-n:]) if x.strip()]
 except: return []
def network_context():
 names=[]
 try:
  names=subprocess.check_output(['ip','-o','link','show'],text=True,stderr=subprocess.DEVNULL,timeout=2)
  names=[x.split(':',2)[1].strip() for x in names.splitlines() if ':' in x]
 except Exception: pass
 vpn=[]
 for n in names:
  low=n.lower()
  if low.startswith(('tun','tap','wg','tailscale')) or low in ('speedify','zt0'):
   vpn.append(n)
 for marker,label in (('tailscaled','Tailscale'),('speedify','Speedify')):
  try:
   if subprocess.call(['pidof',marker],stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL)==0 and label not in vpn: vpn.append(label)
  except Exception: pass
 return {'vpn':bool(vpn),'vpn_names':vpn,'note':('Test reflects router traffic through '+', '.join(vpn)+'.' if vpn else 'No VPN path detected; test reflects the router WAN path.')}
def bandwidth_mbps(value): return round(float(value)*8/1_000_000,2)
def clamp_progress(value): return max(0.0,min(1.0,float(value)))
def parse_jsonl_record(record):
 if len(record if isinstance(record,bytes) else record.encode('utf-8'))>maxout: raise ValueError('oversized_jsonl_record')
 return json.loads(record)
def reduce_event(event):
 kind=event.get('type')
 if kind=='testStart':
  return dict({'phase':'starting','progress':0.0},**{key:event.get(key) for key in ('isp','interface','server')})
 if kind=='ping':
  ping=event.get('ping') or {}
  return {'phase':'ping','progress':clamp_progress(ping.get('progress',0)),'ping_ms':float(ping.get('latency',0)),'jitter_ms':float(ping.get('jitter',0))}
 if kind in ('download','upload'):
  row=event.get(kind) or {}
  return {'phase':kind,'progress':clamp_progress(row.get('progress',0)),kind+'_mbps':bandwidth_mbps(row.get('bandwidth',0)),'loaded_ping_ms':float((row.get('latency') or {}).get('iqm',0))}
 if kind=='result':
  result={key:event.get(key) for key in ('ping','download','upload','packetLoss','isp','interface','server')}
  result['result']={key:(event.get('result') or {}).get(key) for key in ('id','url')}
  return {'phase':'complete','progress':1.0,'result':result}
 return None
def valid_job_id(value): return isinstance(value,str) and re.fullmatch(r'[0-9a-f]{32}',value) is not None
def jobfile(job_id): return os.path.join(jobsdir,job_id+'.json')
def localjobfile(run_id): return os.path.join(localjobsdir,run_id+'.json')
def readjob(job_id):
 try:
  with open(jobfile(job_id)) as f: return json.load(f)
 except Exception: return None
def writejob(job_id,state): atomic_write(jobfile(job_id),json.dumps(state,separators=(',',':')))
def live_ttl():
 try:
  value=int(os.environ.get('OOKLA_LIVE_JOB_TTL','600'))
  return value if value>=0 else 600
 except Exception: return 600
def live_stale_grace():
 try:
  value=int(os.environ.get('OOKLA_LIVE_STALE_GRACE','10'))
  return value if value>=0 else 10
 except Exception: return 10
def local_run_ttl():
 try:
  value=int(os.environ.get('OOKLA_LOCAL_RUN_TTL','600'))
  return value if value>=0 else 600
 except Exception: return 600
def local_run_lease():
 try:
  value=int(os.environ.get('OOKLA_LOCAL_RUN_LEASE','15'))
  return value if value>0 else 15
 except Exception: return 15
def local_heartbeat_interval(): return min(5,max(1,local_run_lease()/3))
def acquire_local_lock():
 deadline=time.monotonic()+2
 while time.monotonic()<deadline:
  held=lock(ignore_starting=True)
  if held!=(None,None): return held
  time.sleep(.005)
 return None,None
def readlocaljob(run_id):
 try:
  with open(localjobfile(run_id)) as f: return json.load(f)
 except Exception: return None
def writelocaljob(run_id,state): atomic_write(localjobfile(run_id),json.dumps(state,separators=(',',':')))
def local_history_item(run_id):
 for item in reversed(readhist()):
  if item.get('run_id')==run_id: return item
 return None
def reconcile_local_commit(run_id,row=None):
 item=local_history_item(run_id)
 if item is None: return None
 now=int(time.time()); repaired=dict(row or {'run_id':run_id,'started':item.get('timestamp',now)})
 repaired.update({'state':'committed','updated':now,'item':item}); writelocaljob(run_id,repaired)
 return item
def cleanup_local_runs():
 now=time.time(); ttl=local_run_ttl(); lease=local_run_lease()
 try: names=os.listdir(localjobsdir)
 except OSError: names=[]
 for name in names:
  if not re.fullmatch(r'[0-9a-f]{32}\.json',name): continue
  path=os.path.join(localjobsdir,name)
  try:
   row=None
   try:
    with open(path) as f: row=json.load(f)
    updated=float(row.get('updated',os.path.getmtime(path)))
   except Exception: updated=os.path.getmtime(path)
   limit=lease if isinstance(row,dict) and row.get('state')=='active' else ttl
   if now-updated>limit: os.unlink(path)
  except Exception: pass
def active_local_run():
 try: names=os.listdir(localjobsdir)
 except OSError: return None
 for name in names:
  if not re.fullmatch(r'[0-9a-f]{32}\.json',name): continue
  row=readlocaljob(name[:-5])
  if row and row.get('state')=='active': return row
 return None
def active_live_run():
 try: names=os.listdir(jobsdir)
 except OSError: return None
 for name in names:
  if not re.fullmatch(r'[0-9a-f]{32}\.json',name): continue
  row=readjob(name[:-5])
  if row and row.get('state') in ('starting','running'): return row
 return None
def heartbeat_local_run(run_id):
 if not valid_job_id(run_id): return {'ok':False,'error':{'code':'invalid_local_run_id'}}
 now=time.time(); row=readlocaljob(run_id)
 try:
  if row.get('state')=='active' and now-float(row.get('updated',0))<local_heartbeat_interval(): return {'ok':True}
 except Exception: pass
 lk=acquire_local_lock()
 if lk==(None,None): return {'ok':False,'error':{'code':'busy'}}
 if isinstance(lk,tuple) and lk[0]=='storage_error': return {'ok':False,'error':{'code':'storage_error'}}
 try:
  cleanup_local_runs(); row=readlocaljob(run_id)
  if row is None: return {'ok':False,'error':{'code':'local_run_not_found'}}
  if row.get('state')!='active': return {'ok':False,'error':{'code':'local_run_not_active'}}
  if time.time()-float(row.get('updated',0))<local_heartbeat_interval(): return {'ok':True}
  row['updated']=int(time.time()); writelocaljob(run_id,row); return {'ok':True}
 except Exception: return {'ok':False,'error':{'code':'storage_error'}}
 finally: unlock(lk)
def stop_spawned_worker(child,job_id):
 deadline=time.monotonic()+.5; group_verified=False
 while child.poll() is None and time.monotonic()<deadline:
  if verified_worker_pid(child.pid,job_id):
   try: os.killpg(child.pid,signal.SIGTERM); group_verified=True
   except OSError: pass
   break
  time.sleep(.01)
 if child.poll() is None and not group_verified:
  try: child.terminate()
  except OSError: pass
 try: child.wait(timeout=1)
 except subprocess.TimeoutExpired:
  try:
   if verified_worker_pid(child.pid,job_id): os.killpg(child.pid,signal.SIGKILL)
   else: child.kill()
  except OSError: pass
  try: child.wait(timeout=1)
  except Exception: pass
def file_identity(st): return (st.st_dev,st.st_ino,st.st_mtime_ns,st.st_size)
def active_cancellation(job_id,now):
 path=startingfile(job_id)
 try:
  if now-os.path.getmtime(path)>live_stale_grace(): return False
  with open(path) as f: marker=json.load(f)
  return marker.get('job_id')==job_id and marker.get('purpose')=='cancelling'
 except Exception: return False
def reconcile_stale_job(job_id,snapshot,snapshot_identity,now):
 held=lock(ignore_starting=True)
 if held==(None,None) or (isinstance(held,tuple) and held[0]=='storage_error'): return
 try:
  if active_cancellation(job_id,now): return
  path=jobfile(job_id); st=os.stat(path)
  if file_identity(st)!=snapshot_identity: return
  current=readjob(job_id)
  if not current or current.get('job_id')!=job_id or current.get('state') not in ('starting','running'): return
  if current.get('pid')!=snapshot.get('pid') or now-st.st_mtime<=live_stale_grace(): return
  if verified_worker_pid(current.get('pid'),job_id): return
  current.update({'ok':False,'state':'error','phase':'error','finished':int(now),'error':{'code':'worker_exited'}}); writejob(job_id,current)
  try: os.unlink(startingfile(job_id))
  except OSError: pass
 finally: unlock(held)
def cleanup_live_jobs():
 now=time.time(); ttl=live_ttl()
 try: names=os.listdir(jobsdir)
 except OSError: names=[]
 for name in names:
  if not re.fullmatch(r'[0-9a-f]{32}\.json',name): continue
  path=os.path.join(jobsdir,name)
  try:
   st=os.stat(path)
   with open(path) as f: row=json.load(f)
   terminal=row.get('state') in ('complete','cancelled','error')
   age=now-st.st_mtime
   if terminal and age>ttl: os.unlink(path)
   elif row.get('state') in ('starting','running') and age>live_stale_grace(): reconcile_stale_job(name[:-5],row,file_identity(st),now)
  except Exception: pass
 try:
  markers=[name for name in os.listdir(jobsdir) if re.fullmatch(r'[0-9a-f]{32}\.starting',name)]
 except OSError: markers=[]
 for name in markers:
  path=os.path.join(jobsdir,name); jid=name[:-9]
  try:
   age=now-os.path.getmtime(path); row=readjob(jid)
   if age>10 and (not row or not verified_worker_pid(row.get('pid'),jid)): os.unlink(path)
  except Exception: pass
def append_history(rec):
 n=retention(); items=readhist()+[rec]; writehist(items if n==0 else items[-n:])
def verified_worker_pid(pid,job_id):
 try:
  with open('/proc/%d/cmdline'%int(pid),'rb') as f: raw=f.read().split(b'\0')
  args=[x.decode('utf-8','surrogateescape') for x in raw if x]
  return os.path.realpath(worker) in [os.path.realpath(x) for x in args] and '--job-id' in args and args[args.index('--job-id')+1]==job_id
 except Exception: return False
def main(req):
 m=req.get('method','')
 if m in ('start_live','live_status','cancel_live','begin_local'): cleanup_live_jobs()
 if m=='live_status':
  jid=req.get('job_id')
  if not valid_job_id(jid): return {'ok':False,'error':{'code':'invalid_job_id'}}
  row=readjob(jid)
  return row if row is not None else {'ok':False,'error':{'code':'job_not_found'}}
 if m=='cancel_live':
  jid=req.get('job_id')
  if not valid_job_id(jid): return {'ok':False,'error':{'code':'invalid_job_id'}}
  row=readjob(jid)
  if row is None: return {'ok':False,'error':{'code':'job_not_found'}}
  if row.get('state') in ('complete','cancelled','error'): return {'ok':False,'error':{'code':'job_not_running'}}
  pid=row.get('pid')
  if not verified_worker_pid(pid,jid): return {'ok':False,'error':{'code':'job_not_running'}}
  reserved=False; held=None; markerpath=startingfile(jid)
  try:
   try:
    fd=os.open(markerpath,os.O_WRONLY|os.O_CREAT|os.O_EXCL,0o600)
    with os.fdopen(fd,'w') as f: json.dump({'job_id':jid,'purpose':'cancelling'},f)
    reserved=True
   except FileExistsError:
    with open(markerpath) as f: marker=json.load(f)
    if marker.get('job_id')!=jid: return {'ok':False,'error':{'code':'busy'}}
    atomic_write(markerpath,json.dumps({'job_id':jid,'purpose':'cancelling'},separators=(',',':')))
    reserved=True
   try: os.killpg(int(pid),signal.SIGTERM)
   except OSError: return {'ok':False,'error':{'code':'job_not_running'}}
   deadline=time.time()+1
   while time.time()<deadline:
    held=lock(ignore_starting=True)
    if held!=(None,None) and not (isinstance(held,tuple) and held[0]=='storage_error'): break
    held=None; time.sleep(.01)
   if held is None: return {'ok':False,'error':{'code':'storage_error'}}
   row=readjob(jid) or row
   if row.get('state') in ('complete','cancelled','error'): return {'ok':False,'error':{'code':'job_not_running'}}
   finished=int(time.time()); row.update({'ok':True,'state':'cancelled','phase':'cancelled','finished':finished}); writejob(jid,row)
   append_history({'id':jid,'timestamp':finished,'kind':'router-internet','outcome':'cancelled'})
   return {'ok':True,'job_id':jid,'state':'cancelled'}
  except Exception: return {'ok':False,'error':{'code':'storage_error'}}
  finally:
   if held is not None: unlock(held)
   if reserved:
    try:
     with open(markerpath) as f: marker=json.load(f)
     if marker.get('job_id')==jid: os.unlink(markerpath)
    except Exception: pass
 if m=='start_live':
  sid=req.get('server_id')
  if sid is not None and (not re.fullmatch(r'[0-9]+',str(sid)) or int(sid)<0): return {'ok':False,'error':{'code':'invalid_server_id'}}
  if not terms_accepted(): return {'ok':False,'error':{'code':'terms_required','message':'Ookla Terms and Privacy Policy acceptance is required'}}
  lk=lock()
  if lk==(None,None): return {'ok':False,'error':{'code':'busy'}}
  if isinstance(lk,tuple) and lk[0]=='storage_error': return {'ok':False,'error':{'code':'storage_error'}}
  jid=new_id(); marked=False; markerpath=startingfile(jid); child=None
  try:
   cleanup_local_runs()
   if active_local_run(): return {'ok':False,'error':{'code':'busy'}}
   try:
    fd=os.open(markerpath,os.O_WRONLY|os.O_CREAT|os.O_EXCL,0o600)
    with os.fdopen(fd,'w') as f: json.dump({'job_id':jid,'purpose':'starting'},f)
    marked=True
   except FileExistsError: return {'ok':False,'error':{'code':'busy'}}
   initial={'ok':True,'job_id':jid,'state':'starting','phase':'starting','started':int(time.time())}
   writejob(jid,initial)
   cmd=[worker,'--job-id',jid]
   if sid is not None: cmd += ['--server-id',str(int(sid))]
   child=subprocess.Popen(cmd,stdin=subprocess.DEVNULL,stdout=subprocess.DEVNULL,stderr=subprocess.DEVNULL,start_new_session=True,close_fds=True)
   initial['pid']=child.pid; writejob(jid,initial)
   return {'ok':True,'job_id':jid}
  except Exception:
   if child is not None: stop_spawned_worker(child,jid)
   try: os.unlink(jobfile(jid))
   except OSError: pass
   if marked:
    try: os.unlink(markerpath)
    except OSError: pass
   return {'ok':False,'error':{'code':'storage_error'}}
  finally: unlock(lk)
 if m=='status':
  try: st=json.load(open(os.path.join(run,'state.json')))
  except: st={'state':'idle'}
  return st
 if m=='history': return {'ok':True,'items':readhist()}
 if m in ('clear_history','delete_history'):
  lk=lock()
  if lk==(None,None): return {'ok':False,'error':{'code':'busy'}}
  if isinstance(lk,tuple) and lk[0]=='storage_error': return {'ok':False,'error':{'code':'storage_error'}}
  try:
   items=[] if m=='clear_history' else [x for x in readhist() if str(x.get('id'))!=str(req.get('id'))]
   writehist(items); return {'ok':True}
  finally: unlock(lk)
 if m=='settings': return {'ok':True,'retention':retention(),'terms_accepted':terms_accepted()}
 if m=='accept_terms':
  try: atomic_write(termsfile,'accepted\n'); return {'ok':True}
  except Exception: return {'ok':False,'error':{'code':'storage_error'}}
 if m=='begin_local':
  lk=acquire_local_lock()
  if lk==(None,None): return {'ok':False,'error':{'code':'busy'}}
  if isinstance(lk,tuple) and lk[0]=='storage_error': return {'ok':False,'error':{'code':'storage_error'}}
  try:
   cleanup_local_runs()
   if active_local_run() or active_live_run(): return {'ok':False,'error':{'code':'busy'}}
   run_id=new_id(); now=int(time.time())
   writelocaljob(run_id,{'run_id':run_id,'state':'active','started':now,'updated':now})
   return {'ok':True,'run_id':run_id,'state':'active'}
  except Exception: return {'ok':False,'error':{'code':'storage_error'}}
  finally: unlock(lk)
 if m=='cancel_local':
  run_id=req.get('run_id')
  if not valid_job_id(run_id): return {'ok':False,'error':{'code':'invalid_local_run_id'}}
  lk=acquire_local_lock()
  if lk==(None,None): return {'ok':False,'error':{'code':'busy'}}
  if isinstance(lk,tuple) and lk[0]=='storage_error': return {'ok':False,'error':{'code':'storage_error'}}
  try:
   cleanup_local_runs(); row=readlocaljob(run_id); committed=reconcile_local_commit(run_id,row)
   if committed is not None: return {'ok':False,'state':'committed','error':{'code':'too_late'}}
   if row is None: return {'ok':False,'error':{'code':'local_run_not_found'}}
   if row.get('state')=='committed': return {'ok':False,'state':'committed','error':{'code':'too_late'}}
   if row.get('state')=='cancelled': return {'ok':True,'run_id':run_id,'state':'cancelled'}
   if row.get('state')!='active': return {'ok':False,'error':{'code':'invalid_local_state'}}
   row.update({'state':'cancelled','updated':int(time.time())}); writelocaljob(run_id,row)
   return {'ok':True,'run_id':run_id,'state':'cancelled'}
  except Exception: return {'ok':False,'error':{'code':'storage_error'}}
  finally: unlock(lk)
 if m=='local_download':
  heartbeat=heartbeat_local_run(req.get('run_id'))
  if not heartbeat.get('ok'): return heartbeat
  try: size=int(req.get('bytes',131072))
  except Exception: size=0
  if size<1024 or size>262144: return {'ok':False,'error':{'code':'invalid_transfer_size'}}
  return {'ok':True,'bytes':size,'data':'0'*size}
 if m=='local_upload':
  heartbeat=heartbeat_local_run(req.get('run_id'))
  if not heartbeat.get('ok'): return heartbeat
  data=req.get('data')
  if not isinstance(data,str) or len(data)<1 or len(data)>262144: return {'ok':False,'error':{'code':'invalid_transfer_size'}}
  return {'ok':True,'bytes':len(data)}
 if m=='record_local':
  try:
   values={k:round(float(req[k]),2) for k in ('download_mbps','upload_mbps','ping_ms')}
   if any(v<0 or v>100000 for v in values.values()): raise ValueError
  except Exception: return {'ok':False,'error':{'code':'invalid_local_result'}}
  run_id=req.get('run_id')
  if run_id is None:
   try:
    rec=dict({'id':new_id(),'timestamp':int(time.time()),'kind':'device-router','outcome':'success'},**values)
    n=retention(); items=readhist()+[rec]; items=items if n==0 else items[-n:]; writehist(items)
    return {'ok':True,'item':rec}
   except Exception: return {'ok':False,'error':{'code':'invalid_local_result'}}
  if not valid_job_id(run_id): return {'ok':False,'error':{'code':'invalid_local_run_id'}}
  lk=acquire_local_lock()
  if lk==(None,None): return {'ok':False,'error':{'code':'busy'}}
  if isinstance(lk,tuple) and lk[0]=='storage_error': return {'ok':False,'error':{'code':'storage_error'}}
  try:
   cleanup_local_runs(); row=readlocaljob(run_id); committed=reconcile_local_commit(run_id,row)
   if committed is not None: return {'ok':True,'run_id':run_id,'state':'committed','item':committed}
   if row is None: return {'ok':False,'error':{'code':'local_run_not_found'}}
   if row.get('state')=='committed': return {'ok':True,'run_id':run_id,'state':'committed','item':row.get('item')}
   if row.get('state')=='cancelled': return {'ok':False,'state':'cancelled','error':{'code':'local_cancelled'}}
   if row.get('state')!='active': return {'ok':False,'error':{'code':'invalid_local_state'}}
   rec=dict({'id':run_id,'run_id':run_id,'timestamp':int(time.time()),'kind':'device-router','outcome':'success'},**values)
   n=retention(); items=[item for item in readhist() if item.get('id')!=run_id]+[rec]
   writehist(items if n==0 else items[-n:])
   row.update({'state':'committed','updated':int(time.time()),'item':rec}); writelocaljob(run_id,row)
   return {'ok':True,'run_id':run_id,'state':'committed','item':rec}
  except Exception: return {'ok':False,'error':{'code':'storage_error'}}
  finally: unlock(lk)
 if m=='servers':
  global _servers_cache,_servers_cache_at
  try:
   c=json.load(open(servercachefile))
   if time.time()-float(c.get('timestamp',0)) < 30 and isinstance(c.get('servers'),list): return {'ok':True,'servers':c['servers']}
  except Exception: pass
  if _servers_cache is not None and time.time()-_servers_cache_at < 30: return {'ok':True,'servers':_servers_cache}
  try:
   with tempfile.TemporaryFile() as tf:
    p=subprocess.run([binary,'--servers','--format=json'],stdout=tf,stderr=subprocess.DEVNULL,timeout=30); tf.seek(0); raw=tf.read(maxout+1)
   if p.returncode or len(raw)>maxout: raise ValueError('server_output_invalid')
   data=json.loads(raw); rows=data.get('servers',data if isinstance(data,list) else [])
   _servers_cache=[{'id':r.get('id'),'name':r.get('name') or r.get('sponsor'),'host':r.get('host'),'port':r.get('port'),'lat':r.get('lat'),'lon':r.get('lon')} for r in rows if isinstance(r,dict)]
   _servers_cache_at=time.time(); atomic_write(servercachefile,json.dumps({'timestamp':_servers_cache_at,'servers':_servers_cache},separators=(',',':'))); return {'ok':True,'servers':_servers_cache}
  except Exception as e: return {'ok':False,'error':{'code':'server_error'}}
 if m!='start': return {'ok':False,'error':{'code':'unknown_method'}}
 sid=req.get('server_id')
 if sid is not None and (not re.fullmatch(r'[0-9]+',str(sid)) or int(sid)<0): return {'ok':False,'error':{'code':'invalid_server_id'}}
 if not terms_accepted(): return {'ok':False,'error':{'code':'terms_required','message':'Ookla Terms and Privacy Policy acceptance is required'}}
 lk=lock()
 if lk==(None,None): return {'ok':False,'error':{'code':'busy'}}
 if isinstance(lk,tuple) and lk[0]=='storage_error': return {'ok':False,'error':{'code':'storage_error'}}
 try:
  cleanup_local_runs()
  if active_local_run(): return {'ok':False,'error':{'code':'busy'}}
  writestate({'state':'running','started':int(time.time())})
  cmd=[binary,'--accept-license','--format=json']
  if sid is not None: cmd += ['--server-id',str(int(sid))]
  with tempfile.TemporaryFile() as tf:
   p=subprocess.run(cmd,stdout=tf,stderr=subprocess.DEVNULL,timeout=120); tf.seek(0); raw=tf.read(maxout+1)
  if len(raw)>maxout: raise ValueError('oversized_output')
  if p.returncode: raise ValueError('speedtest_failed')
  try: result=json.loads(raw)
  except: raise ValueError('malformed_json')
  rec={'id':new_id(),'timestamp':int(time.time()),'kind':'router-internet','server_id':result.get('server',{}).get('id',sid),'server':result.get('server',{}),'latency':result.get('ping',{}).get('latency'),'download':result.get('download',{}),'upload':result.get('upload',{}),'isp':result.get('isp'),'outcome':'success'}
  n=retention(); items=readhist()+[rec]; items=items if n==0 else items[-n:]
  writehist(items)
  writestate({'state':'result','result':result,'finished':int(time.time())})
  result['network_context']=network_context()
  return {'ok':True,'result':result}
 except Exception as e:
  code='timeout' if isinstance(e,subprocess.TimeoutExpired) else ('output_too_large' if str(e)=='oversized_output' else ('speedtest_failed' if str(e)=='speedtest_failed' else 'malformed_output'))
  try:
   rec={'id':new_id(),'timestamp':int(time.time()),'kind':'router-internet','outcome':'error','error':{'code':code}}; n=retention(); items=readhist()+[rec]; items=items if n==0 else items[-n:]; writehist(items); writestate({'state':'error','error':{'code':code}})
  except: pass
  return {'ok':False,'error':{'code':code}}
 finally: unlock(lk)
if __name__=='__main__':
 try: req=json.loads(sys.argv[1] if len(sys.argv)>1 else sys.stdin.read()); out(main(req))
 except Exception as e: out({'ok':False,'error':{'code':'invalid_request'}})
